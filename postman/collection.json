    {
      "name": "TC-API-006 Get Posts with Query Parameters",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Returns limited results\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.length).to.be.lessThanOrEqual(5);",
              "});",
              "",
              "pm.test(\"All posts are from userId 1\", function () {",
              "    var jsonData = pm.response.json();",
              "    jsonData.forEach(function(post) {",
              "        pm.expect(post.userId).to.equal(1);",
              "    });",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/posts?userId={{user_id}}&_limit=5",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "posts"
          ],
          "query": [
            {
              "key": "userId",
              "value": "{{user_id}}"
            },
            {
              "key": "_limit",
              "value": "5"
            }
          ]
        }
      }
    }
  ]
}
